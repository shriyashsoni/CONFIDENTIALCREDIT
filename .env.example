# Copy this file to .env and fill in your values
# Never commit .env to git

# Your deployer wallet private key (with 0x prefix)
PRIVATE_KEY=0x...

# Arbitrum Sepolia RPC (default public endpoint usually works)
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Deployed contract addresses (fill in after running deploy script)
NEXT_PUBLIC_CREDIT_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_VAULT_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_USDC_CONTRACT_ADDRESS=0x...

# Chain ID for Arbitrum Sepolia
NEXT_PUBLIC_CHAIN_ID=421614
